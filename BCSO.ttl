@prefix : <https://w3id.org/BCSO#> .
@prefix crm: <http://www.cidoc-crm.org/cidoc-crm/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix osdba: <https://w3id.org/OSDBA#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@base <https://w3id.org/BCSO#> .

<https://w3id.org/BCSO> rdf:type owl:Ontology ;
                         dcterms:creator "Meng Jiang" ;
                         dcterms:license <http://creativecommons.org/licenses/by/4.0/> ;
                         dcterms:title "BCSO: A Bilingual Ontology for Bronze Casting Sites with Archaeometallurgical Production Chain Knowledge"@en ,
                                       "BCSO：一个包含考古冶金生产链知识的青铜铸造遗址双语本体"@zh ;
                         owl:versionInfo "1.0" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/creator
dcterms:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
dcterms:license rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
dcterms:title rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#closeMatch
skos:closeMatch rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#exactMatch
skos:exactMatch rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.cidoc-crm.org/cidoc-crm/P14_carried_out_by
crm:P14_carried_out_by rdf:type owl:ObjectProperty .


###  http://www.cidoc-crm.org/cidoc-crm/P1_is_identified_by
crm:P1_is_identified_by rdf:type owl:ObjectProperty .


###  http://www.cidoc-crm.org/cidoc-crm/P45_consists_of
crm:P45_consists_of rdf:type owl:ObjectProperty .


###  http://www.cidoc-crm.org/cidoc-crm/P46_is_composed_of
crm:P46_is_composed_of rdf:type owl:ObjectProperty .


###  http://www.cidoc-crm.org/cidoc-crm/P53_has_former_or_current_location
crm:P53_has_former_or_current_location rdf:type owl:ObjectProperty .


###  http://www.cidoc-crm.org/cidoc-crm/P67i_is_referred_to_by
crm:P67i_is_referred_to_by rdf:type owl:ObjectProperty .


###  http://www.cidoc-crm.org/cidoc-crm/P69_has_association_with
crm:P69_has_association_with rdf:type owl:ObjectProperty .


###  https://w3id.org/BCSO#belongsToPeriod
###  https://w3id.org/BCSO#belongsToPeriod
:belongsToPeriod rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf crm:P1_is_identified_by ;
                 rdfs:range :Period ;
                 rdfs:comment "Indicates the historical period to which the site, feature, or object belongs."@en ,
                              "指示遗址、遗迹或遗物所属的历史时期。"@zh ;
                 rdfs:label "belongs to period"@en ,
                            "所属时期是"@zh .


###  https://w3id.org/BCSO#siteBelongsToPeriod
:siteBelongsToPeriod rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf :belongsToPeriod ;
                     rdfs:domain :CastingSite ;
                     rdfs:range :Period ;
                     rdfs:comment "Indicates the historical period to which the casting site belongs."@en ,
                                  "指示铸造遗址所属的历史时期。"@zh ;
                     rdfs:label "site belongs to period"@en ,
                                "遗址所属时期是"@zh .


###  https://w3id.org/BCSO#featureBelongsToPeriod
:featureBelongsToPeriod rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf :belongsToPeriod ;
                        rdfs:domain :AnthropicFeature ;
                        rdfs:range :Period ;
                        rdfs:comment "Indicates the historical period to which the anthropic feature belongs."@en ,
                                     "指示人为遗迹单元所属的历史时期。"@zh ;
                        rdfs:label "feature belongs to period"@en ,
                                   "遗迹所属时期是"@zh .


###  https://w3id.org/BCSO#objectBelongsToPeriod
:objectBelongsToPeriod rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf :belongsToPeriod ;
                       rdfs:domain :ExcavatedObject ;
                       rdfs:range :Period ;
                       rdfs:comment "Indicates the historical period to which the excavated object belongs."@en ,
                                    "指示出土遗物所属的历史时期。"@zh ;
                       rdfs:label "object belongs to period"@en ,
                                  "遗物所属时期是"@zh .


###  https://w3id.org/BCSO#carriedOutBy
:carriedOutBy rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf crm:P14_carried_out_by ;
              rdfs:domain :ExcavationActivity ;
              rdfs:range :ArchaeologicalUnit ;
              rdfs:comment "Indicates the archaeological unit that carried out the excavation activity."@en ,
                           "指示执行发掘活动的考古单位。"@zh ;
              rdfs:label "carried out by"@en ,
                         "由单位执行"@zh .


###  https://w3id.org/BCSO#conductedAtSite
:conductedAtSite rdf:type owl:ObjectProperty ;
                 rdfs:domain :ExcavationActivity ;
                 rdfs:range :CastingSite ;
                 rdfs:comment "Indicates the casting site where the excavation activity was conducted."@en ,
                              "指示发掘活动进行的铸造遗址。"@zh ;
                 rdfs:label "conducted at site"@en ,
                            "在遗址进行活动"@zh .


###  https://w3id.org/BCSO#excavatedFrom
:excavatedFrom rdf:type owl:ObjectProperty ;
               rdfs:domain :ExcavatedObject ;
               rdfs:range :AnthropicFeature ;
               rdfs:comment "Indicates the anthropic feature from which the object was excavated."@en ,
                            "指示遗物出土的遗迹单元。"@zh ;
               rdfs:label "excavated from"@en ,
                          "出土于遗迹"@zh .


###  https://w3id.org/BCSO#hasAssociationWith
:hasAssociationWith rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf crm:P69_has_association_with ;
                    rdfs:domain :ProductionTechnology ;
                    rdfs:range :ProductionTechnology ;
                    rdfs:comment "描述生产技术间的关联，如制范技术与铸造技术的关联"@zh ;
                    rdfs:label "has association with"@en ,
                               "有关联"@zh .


###  https://w3id.org/BCSO#hasFeature
:hasFeature rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf crm:P46_is_composed_of ;
            rdfs:domain :CastingSite ;
            rdfs:range :AnthropicFeature ;
            rdfs:comment "Indicates the anthropic features contained within a casting site."@en ,
                         "指示铸造遗址包含的遗迹单元。"@zh ;
            rdfs:label "has feature"@en ,
                       "包含遗迹"@zh .


###  https://w3id.org/BCSO#involvesTechnique
###  https://w3id.org/BCSO#involvesTechnique
:involvesTechnique rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf crm:P67i_is_referred_to_by ;
                   rdfs:range :ProductionTechnology ;
                   rdfs:comment "Indicates the production technology involved in a feature or object."@en ,
                                "指示遗迹或遗物涉及的生产技术。"@zh ;
                   rdfs:label "involves technique"@en ,
                              "涉及技术"@zh .


###  https://w3id.org/BCSO#featureInvolvesTechnique
:featureInvolvesTechnique rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf :involvesTechnique ;
                          rdfs:domain :AnthropicFeature ;
                          rdfs:range :ProductionTechnology ;
                          rdfs:comment "Indicates the production technology involved in an anthropic feature."@en ,
                                       "指示人为遗迹单元涉及的生产技术。"@zh ;
                          rdfs:label "feature involves technique"@en ,
                                     "遗迹涉及技术"@zh .


###  https://w3id.org/BCSO#objectInvolvesTechnique
:objectInvolvesTechnique rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf :involvesTechnique ;
                         rdfs:domain :ExcavatedObject ;
                         rdfs:range :ProductionTechnology ;
                         rdfs:comment "Indicates the production technology involved in an excavated object."@en ,
                                      "指示出土遗物涉及的生产技术。"@zh ;
                         rdfs:label "object involves technique"@en ,
                                    "遗物涉及技术"@zh .


###  https://w3id.org/BCSO#isComposedOf
:isComposedOf rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf crm:P45_consists_of ;
              rdfs:domain :ExcavatedObject ;
              rdfs:range :MetalMaterial ;
              rdfs:comment "Indicates the material composition of an anthropic feature."@en ,
                           "指示人为遗迹单元的材料构成。"@zh ;
              rdfs:label "is composed of"@en ,
                         "由...构成"@zh .


###  https://w3id.org/BCSO#isLocatedIn
:isLocatedIn rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf crm:P53_has_former_or_current_location ;
             rdfs:domain :CastingSite ;
             rdfs:range :Region ;
             rdfs:comment "Indicates the geographical region where the site is located."@en ,
                          "指示遗址所在的地理区域。"@zh ;
             rdfs:label "is located in"@en ,
                        "位于"@zh .


###  https://w3id.org/BCSO#locatedInAdminRegion
:locatedInAdminRegion rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf crm:P1_is_identified_by ;
                      rdfs:domain :CastingSite ;
                      rdfs:range :AdministrativeRegion ;
                      rdfs:comment "Indicates the administrative region where the site is located."@en ,
                                   "指示遗址所在的行政区划。"@zh ;
                      rdfs:label "located in administrative region"@en ,
                                 "位于行政区划"@zh .


###  https://w3id.org/BCSO#wasFoundAt
:wasFoundAt rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf crm:P53_has_former_or_current_location ;
            rdfs:domain :ExcavatedObject ;
            rdfs:range :Region ;
            rdfs:comment "Indicates the location where the object was found."@en ,
                         "指示遗物发现的地点。"@zh ;
            rdfs:label "was found at"@en ,
                       "出土地点是"@zh .


#################################################################
#    Data properties
#################################################################

###  https://w3id.org/BCSO#hasDimension
###  https://w3id.org/BCSO#hasDimension
:hasDimension rdf:type owl:DatatypeProperty ;
              rdfs:range rdf:langString ;
              rdfs:comment "遗物或遗迹单元具有尺寸信息（文本描述）"@zh ;
              rdfs:label "has dimension"@en ,
                         "具有尺寸"@zh .


###  https://w3id.org/BCSO#featureHasDimension
:featureHasDimension rdf:type owl:DatatypeProperty ;
                     rdfs:subPropertyOf :hasDimension ;
                     rdfs:domain :AnthropicFeature ;
                     rdfs:range rdf:langString ;
                     rdfs:comment "人为遗迹单元具有尺寸信息（文本描述）"@zh ;
                     rdfs:label "feature has dimension"@en ,
                                "遗迹具有尺寸"@zh .


###  https://w3id.org/BCSO#objectHasDimension
:objectHasDimension rdf:type owl:DatatypeProperty ;
                    rdfs:subPropertyOf :hasDimension ;
                    rdfs:domain :ExcavatedObject ;
                    rdfs:range rdf:langString ;
                    rdfs:comment "出土遗物具有尺寸信息（文本描述）"@zh ;
                    rdfs:label "object has dimension"@en ,
                               "遗物具有尺寸"@zh .


###  https://w3id.org/BCSO#hasSpatialRelation
:hasSpatialRelation rdf:type owl:DatatypeProperty ;
                    rdfs:domain :AnthropicFeature ;
                    rdfs:range xsd:string ;
                    rdfs:comment "遗迹单元在遗址中的空间位置关系（如位于遗址东南角、F6东侧等）"@zh ;
                    rdfs:label "has spatial relation"@en ,
                               "具有空间关系"@zh .


###  https://w3id.org/BCSO#hasStratigraphicRelation
:hasStratigraphicRelation rdf:type owl:DatatypeProperty ;
                          rdfs:domain :AnthropicFeature ;
                          rdfs:range xsd:string ;
                          rdfs:comment "遗迹单元的地层关系（如打破H31、叠压F7等）"@zh ;
                          rdfs:label "has stratigraphic relation"@en ,
                                     "具有地层关系"@zh .


#################################################################
#    Classes
#################################################################

###  http://www.cidoc-crm.org/cidoc-crm/E18_Physical_Thing
crm:E18_Physical_Thing rdf:type owl:Class .


###  http://www.cidoc-crm.org/cidoc-crm/E25_Human-Made_Feature
crm:E25_Human-Made_Feature rdf:type owl:Class .


###  http://www.cidoc-crm.org/cidoc-crm/E27_Site
crm:E27_Site rdf:type owl:Class .


###  http://www.cidoc-crm.org/cidoc-crm/E29_Design_or_Procedure
crm:E29_Design_or_Procedure rdf:type owl:Class .


###  http://www.cidoc-crm.org/cidoc-crm/E41_Appellation
crm:E41_Appellation rdf:type owl:Class .


###  http://www.cidoc-crm.org/cidoc-crm/E53_Place
crm:E53_Place rdf:type owl:Class .


###  http://www.cidoc-crm.org/cidoc-crm/E57_Material
crm:E57_Material rdf:type owl:Class .


###  http://www.cidoc-crm.org/cidoc-crm/E74_Group
crm:E74_Group rdf:type owl:Class .


###  http://www.cidoc-crm.org/cidoc-crm/E7_Activity
crm:E7_Activity rdf:type owl:Class .


###  https://w3id.org/BCSO#AbsoluteDate
:AbsoluteDate rdf:type owl:Class ;
              rdfs:subClassOf :Period ;
              rdfs:comment "An absolute date represents a specific point in time, such as a particular year."@en ,
                           "绝对年代表示具体的时间点，如某一年。"@zh ;
              rdfs:label "Absolute Date"@en ,
                         "绝对年代"@zh .


###  https://w3id.org/BCSO#AdministrativeRegion
:AdministrativeRegion rdf:type owl:Class ;
                      rdfs:subClassOf crm:E41_Appellation ;
                      rdfs:comment "Administrative divisions such as provinces, cities, and counties where the site is located."@en ,
                                   "遗址所在的行政区划，如省、市、县。"@zh ;
                      rdfs:label "Administrative Region"@en ,
                                 "行政区划"@zh .


###  https://w3id.org/BCSO#Annealing
:Annealing rdf:type owl:Class ;
           rdfs:subClassOf :HeatTreatmentTech ;
           rdfs:comment "A heat treatment process to reduce hardness and increase ductility of metal."@en ,
                        "一种热处理工艺，用于降低金属硬度、增加延展性。"@zh ;
           rdfs:label "Annealing"@en ,
                      "退火处理"@zh .


###  https://w3id.org/BCSO#AnthropicFeature
:AnthropicFeature rdf:type owl:Class ;
                  rdfs:subClassOf crm:E25_Human-Made_Feature ;
                  rdfs:comment "Human-made features at the casting site, including workshops, kilns, pits, etc."@en ,
                               "铸铜遗址中的人为建造遗迹，包括作坊、窑址、坑等。"@zh ;
                  rdfs:label "Anthropic Feature"@en ,
                             "人为遗迹单元"@zh .


###  https://w3id.org/BCSO#Anvil
:Anvil rdf:type owl:Class ;
       rdfs:subClassOf :FinishingTool ;
       rdfs:comment "A tool used for hammering and shaping metal during finishing process."@en ,
                    "后期处理过程中用于锤打和修整金属的工具。"@zh ;
       rdfs:label "Anvil"@en ,
                  "砧子"@zh .


###  https://w3id.org/BCSO#ArchaeologicalUnit
:ArchaeologicalUnit rdf:type owl:Class ;
                    rdfs:subClassOf crm:E74_Group ;
                    rdfs:comment "The organization responsible for archaeological excavation."@en ,
                                 "负责考古发掘工作的单位。"@zh ;
                    rdfs:label "Archaeological Unit"@en ,
                               "考古单位"@zh .


###  https://w3id.org/BCSO#ArsenicalBronze
:ArsenicalBronze rdf:type owl:Class ;
                 rdfs:subClassOf :CopperBasedMaterial ;
                 rdfs:comment "Copper alloy with arsenic as the main alloying element."@en ,
                              "以砷为主要合金元素的铜合金。"@zh ;
                 rdfs:label "Arsenical Bronze"@en ,
                            "砷青铜"@zh .


###  https://w3id.org/BCSO#AssemblyArea
:AssemblyArea rdf:type owl:Class ;
              rdfs:subClassOf :FinishingArea ;
              rdfs:comment "Area where different cast parts are assembled together."@en ,
                           "将不同铸造部件组装在一起的区域。"@zh ;
              rdfs:label "Assembly Area"@en ,
                         "装配区"@zh .


###  https://w3id.org/BCSO#BellowsPipe
:BellowsPipe rdf:type owl:Class ;
             rdfs:subClassOf :SmeltingEquipment ;
             rdfs:comment "Pipe used to blow air into the furnace to increase combustion temperature."@en ,
                          "用于向炉内鼓风以提高燃烧温度的管道。"@zh ;
             rdfs:label "Bellows Pipe"@en ,
                        "鼓风管"@zh .


###  https://w3id.org/BCSO#BlockMould
:BlockMould rdf:type owl:Class ;
            rdfs:subClassOf :OuterMould ;
            rdfs:comment "Mould made in sections that can be assembled and disassembled."@en ,
                         "可拆装的分块式铸范。"@zh ;
            rdfs:label "Block Mould"@en ,
                       "块范"@zh .


###  https://w3id.org/BCSO#BlockMouldCasting
:BlockMouldCasting rdf:type owl:Class ;
                   rdfs:subClassOf :CastingTechnique ;
                   rdfs:comment "Casting technique using block moulds made of multiple sections."@en ,
                                "使用多块组合铸范的铸造技术。"@zh ;
                   rdfs:label "Block Mould Casting"@en ,
                              "块范铸造"@zh .


###  https://w3id.org/BCSO#CarvingKnife
:CarvingKnife rdf:type owl:Class ;
              rdfs:subClassOf :FinishingTool ;
              rdfs:comment "Tool used for carving fine details on cast objects."@en ,
                           "用于在铸件上雕刻细部纹饰的工具。"@zh ;
              rdfs:label "Carving Knife"@en ,
                         "刻刀"@zh .


###  https://w3id.org/BCSO#CastingEquipment
:CastingEquipment rdf:type owl:Class ;
                  rdfs:subClassOf :ProductionEquipment ;
                  rdfs:comment "Equipment used in the casting process."@en ,
                               "浇铸过程中使用的设备。"@zh ;
                  rdfs:label "Casting Equipment"@en ,
                             "浇铸设备"@zh .


###  https://w3id.org/BCSO#CastingFacility
:CastingFacility rdf:type owl:Class ;
                 rdfs:subClassOf :AnthropicFeature ;
                 rdfs:comment "Facilities specifically designed for casting operations."@en ,
                              "专门用于浇铸操作的设施。"@zh ;
                 rdfs:label "Casting Facility"@en ,
                            "浇铸设施"@zh .


###  https://w3id.org/BCSO#CastingPit
:CastingPit rdf:type owl:Class ;
            rdfs:subClassOf :Pit ;
            rdfs:comment "Pit used for casting operations."@en ,
                         "用于浇铸操作的坑。"@zh ;
            rdfs:label "Casting Pit"@en ,
                       "浇铸坑"@zh .


###  https://w3id.org/BCSO#CastingPlatform
:CastingPlatform rdf:type owl:Class ;
                 rdfs:subClassOf :CastingFacility ;
                 rdfs:comment "Platform used for casting operations."@en ,
                              "用于浇铸操作的平台。"@zh ;
                 rdfs:label "Casting Platform"@en ,
                            "浇铸台"@zh .


###  https://w3id.org/BCSO#CastingProduct
:CastingProduct rdf:type owl:Class ;
                rdfs:subClassOf :ExcavatedObject ;
                rdfs:comment "The final product of the casting process."@en ,
                             "铸造过程的最终产品。"@zh ;
                rdfs:label "Casting Product"@en ,
                           "铸造产品"@zh .


###  https://w3id.org/BCSO#CastingSite
:CastingSite rdf:type owl:Class ;
             rdfs:subClassOf crm:E27_Site ;
             rdfs:comment "Archaeological site where bronze casting activities took place."@en ,
                          "进行青铜铸造活动的考古遗址。"@zh ;
             rdfs:label "Casting Site"@en ,
                        "铸造遗址"@zh .


###  https://w3id.org/BCSO#CastingTechnique
:CastingTechnique rdf:type owl:Class ;
                  rdfs:subClassOf :ProductionTechnology ;
                  rdfs:comment "Techniques used in the bronze casting process."@en ,
                               "青铜铸造过程中使用的技术。"@zh ;
                  rdfs:label "Casting Technique"@en ,
                             "铸造技术"@zh .


###  https://w3id.org/BCSO#CastingWorkshop
:CastingWorkshop rdf:type owl:Class ;
                 rdfs:subClassOf :CastingSite ;
                 rdfs:comment "Workshop specifically for bronze casting production."@en ,
                              "专门用于铸铜生产的作坊。"@zh ;
                 rdfs:label "Casting Workshop"@en ,
                            "铸铜作坊"@zh .


###  https://w3id.org/BCSO#CharcoalSmelting
:CharcoalSmelting rdf:type owl:Class ;
                  rdfs:subClassOf :SmeltingTechnology ;
                  rdfs:comment "Smelting process using charcoal as fuel and reducing agent."@en ,
                               "使用木炭作为燃料和还原剂的熔炼工艺。"@zh ;
                  rdfs:label "Charcoal Smelting"@en ,
                             "木炭还原熔炼"@zh .


###  https://w3id.org/BCSO#City
:City rdf:type owl:Class ;
      rdfs:subClassOf :AdministrativeRegion ;
      rdfs:comment "City-level administrative division."@en ,
                   "市级行政区划。"@zh ;
      rdfs:label "City"@en ,
                 "市"@zh .


###  https://w3id.org/BCSO#ClayPiledFurnace
:ClayPiledFurnace rdf:type owl:Class ;
                  rdfs:subClassOf :SmeltingFacility ;
                  rdfs:comment "Furnace built by piling clay, used in bronze casting."@en ,
                               "通过堆筑草泥方式建造的熔炉，用于青铜铸造。"@zh ;
                  rdfs:label "Clay Piled Furnace"@en ,
                             "草泥堆筑式熔炉"@zh .


###  https://w3id.org/BCSO#ClayPreparation
:ClayPreparation rdf:type owl:Class ;
                 rdfs:subClassOf :MouldMakingTech ;
                 rdfs:comment "Process of preparing clay for mould making."@en ,
                              "制备制范用泥料的过程。"@zh ;
                 rdfs:label "Clay Preparation"@en ,
                            "泥料配制"@zh .


###  https://w3id.org/BCSO#ClayStripBuiltFurnace
:ClayStripBuiltFurnace rdf:type owl:Class ;
                       rdfs:subClassOf :SmeltingFacility ;
                       rdfs:comment "Furnace built by coiling clay strips, used in bronze casting."@en ,
